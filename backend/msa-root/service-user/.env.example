# service-user/.env.example
# Copy values into .env or set environment variables in your runtime.

# Service
SPRING_APPLICATION_NAME=service-user
SERVER_PORT=8010

# Eureka
EUREKA_DEFAULT_ZONE=http://localhost:8100/eureka/
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true

# Database
DB_DRIVER=org.postgresql.Driver
DB_HOST=localhost
DB_PORT=6000
DB_NAME=db_user
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_MAX_POOL_SIZE=10

# JPA / Flyway
JPA_HIBERNATE_DDL=none
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# Notes:
# - Do NOT commit a file named .env with secrets.
# - For local testing, copy this file to ../../.env and edit values or set env vars per-service.
