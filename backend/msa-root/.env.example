# .env.example - safe to commit
# Copy this to .env and fill in real values for local development.

# Eureka (Discovery)
EUREKA_DEFAULT_ZONE=http://localhost:8100/eureka/
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true

# Database (service-user)
DB_HOST=192.168.0.25
DB_PORT=6000
DB_NAME=db_user
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DRIVER=org.postgresql.Driver
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}

# service-user specific
SERVICE_USER_NAME=service-user
SERVICE_USER_PORT=8010

# JPA settings
JPA_HIBERNATE_DDL=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# Spring-Boot mapping convenience
SPRING_DATASOURCE_URL=${DB_URL}
SPRING_DATASOURCE_USERNAME=${DB_USERNAME}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}
SPRING_DATASOURCE_DRIVER_CLASS_NAME=${DB_DRIVER}
SPRING_APPLICATION_NAME=${SERVICE_USER_NAME}
SERVER_PORT=${SERVICE_USER_PORT}
