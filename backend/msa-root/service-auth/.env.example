# service-auth/.env.example
SPRING_APPLICATION_NAME=service-auth
SERVER_PORT=7000

DB_DRIVER=org.postgresql.Driver
DB_HOST=localhost
DB_PORT=6000
DB_NAME=db_user
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_MAX_POOL_SIZE=10

# Redis (refresh tokens)
REDIS_HOST=localhost
REDIS_PORT=6379

EUREKA_DEFAULT_ZONE=http://localhost:8100/eureka/
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true

# Token
TOKEN_SECRET=your_base64_secret_here
TOKEN_EXPIRATION_TIME=3600000
TOKEN_REFRESH_TIME=1209600000
