# service-delivery/.env.example
SPRING_APPLICATION_NAME=service-delivery
SERVER_PORT=8050

DB_DRIVER=org.postgresql.Driver
DB_HOST=localhost
DB_PORT=6000
DB_NAME=db_delivery
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_MAX_POOL_SIZE=10

EUREKA_DEFAULT_ZONE=http://localhost:8100/eureka/
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
