<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_container_low"
    android:orientation="horizontal"
    android:padding="@dimen/page_horizontal_padding"
    android:layout_marginBottom="@dimen/spacing_2">

    <!-- 1/3 Image -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/iv_store_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_container"
                android:contentDescription="가게 이미지"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Hot badge -->
        <TextView
            android:id="@+id/tv_hot_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/spacing_1"
            android:background="@drawable/bg_gradient_primary"
            android:paddingHorizontal="@dimen/spacing_2"
            android:paddingVertical="2dp"
            android:text="Hot"
            android:textColor="#FFFFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 2/3 Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_4"
        android:layout_weight="2"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_store_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="가게 이름"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_3"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_free_delivery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_success"
                android:paddingHorizontal="@dimen/spacing_2"
                android:paddingVertical="2dp"
                android:text="무료배달"
                android:textColor="@color/on_secondary_container"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_min_order"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_2"
                android:text="최소주문 0원"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
