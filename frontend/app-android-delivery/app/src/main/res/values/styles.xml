<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base parent style -->
    <style name="Widget.App" parent="" />

    <!-- ═══ Card Styles: Subtle elevation + rounded corners ═══ -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="strokeWidth">1dp</item>                        <!-- 0dp → 1dp -->
        <item name="strokeColor">@color/outline_variant</item>     <!-- 추가 -->
        <item name="android:layout_marginBottom">@dimen/spacing_3</item>
    </style>
    <style name="Widget.App.Card.Elevated">
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardElevation">@dimen/elevation_md</item>
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="strokeWidth">0dp</item>
    </style>
    <style name="Widget.App.Card.Tonal">
        <item name="cardBackgroundColor">@color/surface_container_low</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="strokeWidth">1dp</item>                        <!-- 0dp → 1dp -->
        <item name="strokeColor">@color/outline_variant</item>     <!-- 추가 -->
    </style>
    <style name="Widget.App.Card.Hero">
        <item name="cardBackgroundColor">@color/primary</item>
        <item name="cardElevation">@dimen/elevation_md</item>
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="strokeWidth">0dp</item>
    </style>
    <!-- Glass Card: frosted translucent -->
    <style name="Widget.App.Card.Glass">
        <item name="cardBackgroundColor">@color/glass_white</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_border</item>
    </style>

    <!-- ═══ Button Styles ═══ -->
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">@dimen/elevation_sm</item>
    </style>
    <style name="Widget.App.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/secondary_container</item>
        <item name="android:textColor">@color/on_secondary_container</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Widget.App.Button.Tertiary" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>
    <style name="Widget.App.Button.Danger" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@color/on_error</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <!-- Gradient/Accent CTA -->
    <style name="Widget.App.Button.Accent" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/tertiary</item>
        <item name="android:textColor">@color/on_tertiary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">@dimen/elevation_sm</item>
    </style>
    <!-- Outlined -->
    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/outline_variant</item>
    </style>

    <!-- ═══ Status Badges ═══ -->
    <style name="Widget.App.Badge" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>
    <style name="Widget.App.Badge.Success">
        <item name="android:background">@drawable/bg_badge_success</item>
        <item name="android:textColor">@color/on_secondary_container</item>
    </style>
    <style name="Widget.App.Badge.Error">
        <item name="android:background">@drawable/bg_badge_error</item>
        <item name="android:textColor">@color/on_error_container</item>
    </style>
    <style name="Widget.App.Badge.Info">
        <item name="android:background">@drawable/bg_badge_info</item>
        <item name="android:textColor">@color/primary</item>
    </style>
    <style name="Widget.App.Badge.New">
        <item name="android:background">@drawable/bg_badge_new</item>
        <item name="android:textColor">@color/on_tertiary_container</item>
    </style>

    <!-- ═══ Input Fields ═══ -->
    <style name="Widget.App.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_container_lowest</item>
        <item name="boxStrokeColor">@color/outline_variant</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
    </style>

    <!-- ═══ Section Header ═══ -->
    <style name="Widget.App.SectionHeader">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">@dimen/spacing_8</item>
        <item name="android:layout_marginBottom">@dimen/spacing_3</item>
    </style>

    <!-- ═══ Chip Styles ═══ -->
    <style name="Widget.App.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/radius_full</item>
        <item name="chipBackgroundColor">@color/surface_container</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- ═══ Bottom Navigation ═══ -->
    <style name="Widget.App.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface_container_lowest</item>
        <item name="itemIconTint">@color/on_surface_variant</item>
        <item name="itemTextColor">@color/on_surface_variant</item>
        <item name="elevation">@dimen/elevation_md</item>
    </style>

    <!-- ═══ Toolbar ═══ -->
    <style name="Widget.App.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/on_surface</item>
        <item name="subtitleTextColor">@color/on_surface_variant</item>
        <item name="titleTextAppearance">@style/TextAppearance.App.Title.Large</item>
    </style>

    <!-- ═══ Divider ═══ -->
    <style name="Widget.App.Divider">
        <item name="android:background">@color/outline_variant</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginVertical">@dimen/spacing_4</item>
    </style>
</resources>